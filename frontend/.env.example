# Ascend — copy to .env.local and fill in real values

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Agent reasoning backend (FastAPI on Railway) for the "Why this match?" modal.
# Local dev: http://localhost:8000
NEXT_PUBLIC_AGENT_API_URL=https://your-railway-app.up.railway.app

GMI_API_KEY=your-gmi-api-key-here
GMI_ENDPOINT=https://api.gmicloud.ai/v1
GMI_MODEL=meta-llama/Llama-3.3-70B-Instruct

