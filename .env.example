# Anthropic (default provider when no GMI key is set)
ANTHROPIC_API_KEY=

# Model identifier used by llm_client. Set to match the active provider:
#   Anthropic direct       -> claude-sonnet-4-6
#   GMI Anthropic route     -> anthropic/claude-sonnet-4.6
#   GMI OpenAI route        -> meta-llama/Llama-3.3-70B-Instruct
DEFAULT_MODEL=claude-sonnet-4-6

# --- GMI inference cloud ---------------------------------------------------
# Get the key at console.gmicloud.ai (Organization Settings -> API Keys).
# llm_client auto-switches to GMI the moment GMI_API_KEY is set.
GMI_API_KEY=

# Route 1 (RECOMMENDED): Anthropic-compatible — keeps Claude models + our SDK.
# Just set GMI_API_KEY above and DEFAULT_MODEL=anthropic/claude-sonnet-4.6.
GMI_BASE_URL=https://api.gmi-serving.com

# Route 2 (optional): OpenAI-compatible for open models (Llama, Minimax M2).
# Set this to activate the OpenAI route instead; leave blank to use Route 1.
GMI_ENDPOINT=

# Phinite multi-agent OS (drop in at kickoff)
PHINITE_API_KEY=
PHINITE_PROJECT=

# Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_match
